# Copy this to .env and fill in values

PORT=3001
NODE_ENV=production

# Generate with: openssl rand -hex 64
JWT_SECRET=your_secret_here

# Path where SQLite DB is stored (Railway: /data/dialed.db)
DB_PATH=/data/dialed.db

# Comma-separated list of allowed origins (leave blank to allow all)
ALLOWED_ORIGINS=
